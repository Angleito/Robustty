# Robustty Music Bot Configuration - OrbStack Optimized
DISCORD_TOKEN=your_discord_bot_token_here
YOUTUBE_API_KEY=your_youtube_api_key_here
APIFY_API_KEY=your_apify_api_key_here

# Performance Configuration
SEARCH_TIMEOUT=30
STREAM_TIMEOUT=300
MAX_QUEUE_SIZE=100

# Discord Voice Protocol v8 Configuration
DISCORD_VOICE_TIMEOUT=30
DISCORD_RECONNECT_TIMEOUT=60

# Logging level
LOG_LEVEL=INFO

# Cookie refresh interval (2 hours = 7200 seconds)
COOKIE_REFRESH_INTERVAL=7200

# Redis Configuration (uses host networking in OrbStack)
REDIS_URL=redis://localhost:6379

# Platform Enable/Disable
YOUTUBE_ENABLED=true
RUMBLE_ENABLED=true
ODYSEE_ENABLED=true
PEERTUBE_ENABLED=true

# VPS Cookie Sync Configuration (for macOS host)
VPS_HOST=your.vps.ip.address
VPS_USER=your-vps-username
SSH_KEY=$HOME/.ssh/robustty_vps
VPS_COOKIE_DIR=/opt/robustty/cookies

# Cookie Monitoring (for VPS)
MAX_AGE_MINUTES=150
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL