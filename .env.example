# Robustty Music Bot Configuration - OrbStack Optimized
DISCORD_TOKEN=your_discord_bot_token_here
YOUTUBE_API_KEY=your_youtube_api_key_here
APIFY_API_KEY=your_apify_api_key_here

# Performance Configuration
SEARCH_TIMEOUT=30
STREAM_TIMEOUT=300
MAX_QUEUE_SIZE=100

# Logging level
LOG_LEVEL=INFO

# Cookie refresh interval (2 hours = 7200 seconds)
COOKIE_REFRESH_INTERVAL=7200

# Redis Configuration
# Local development (OrbStack with host networking): redis://localhost:6379
# VPS deployment (Docker bridge networking): redis://redis:6379
# External Redis server: redis://your-redis-server:6379
REDIS_URL=redis://localhost:6379

# Platform Enable/Disable
YOUTUBE_ENABLED=true
RUMBLE_ENABLED=true
ODYSEE_ENABLED=true
PEERTUBE_ENABLED=true

# VPS Cookie Sync Configuration (for cookie extractor)
AUTO_SYNC_VPS=false  # Set to true to enable automatic VPS sync
VPS_HOST=your-vps-ip  # Your VPS IP address (e.g., 164.92.93.19)
VPS_USER=root  # VPS username
VPS_PATH=~/Robustty/cookies  # Path on VPS to sync cookies
SSH_KEY_PATH=~/.ssh/yeet  # Path to SSH private key for VPS access

# Fallback System Configuration
ENABLE_FALLBACKS=true  # Enable fallback system for all platforms
MAX_FALLBACK_DURATION_HOURS=24  # How long to use fallbacks before retrying primary
RETRY_INTERVAL_MINUTES=30  # How often to retry primary methods during fallback
SHOW_FALLBACK_INDICATORS=true  # Show visual indicators when using fallback methods

# YouTube Fallback Configuration
YOUTUBE_ENABLE_FALLBACKS=true  # Enable YouTube-specific fallback system
YOUTUBE_ENABLE_SEARCH_CACHING=true  # Cache search results for fallback use
YOUTUBE_CACHE_TTL_SECONDS=300  # How long to cache search results (5 minutes)
YOUTUBE_MAX_CACHE_SIZE=100  # Maximum number of cached search results
YOUTUBE_ENABLE_CONCURRENT_STRATEGIES=true  # Try multiple strategies simultaneously
YOUTUBE_SEARCH_TIMEOUT_PER_STRATEGY=15  # Timeout for each search strategy (seconds)
YOUTUBE_MAX_CONCURRENT_STRATEGIES=3  # Max strategies to try at once
YOUTUBE_QUOTA_WARNING_THRESHOLD=100  # Warn when API quota drops below this
YOUTUBE_ENABLE_PROGRESSIVE_DEGRADATION=true  # Gradually reduce features when quota is low